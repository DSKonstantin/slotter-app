{
  "expo": {
    "name": "Slotter",
    "slug": "slotter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon/icon.png",
    "scheme": "slotter",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleLocalizations": [
          "ru",
          "en",
          "ru",
          "en"
        ],
        "NSUserNotificationsUsageDescription": "Разрешите $(PRODUCT_NAME) отправлять уведомления о записях, сообщениях и изменениях в расписании",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.slotter.application"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#232323",
        "foregroundImage": "./assets/images/app-icon/android-icon-foreground.png",
        "backgroundImage": "./assets/images/app-icon/android-icon-background.png",
        "monochromeImage": "./assets/images/app-icon/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.slotter.application",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icon/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "ru",
              "en"
            ],
            "android": [
              "ru",
              "en"
            ]
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Разрешите $(PRODUCT_NAME) доступ к вашим фотографиям",
          "cameraPermission": "Разрешить $(PRODUCT_NAME) открыть камеру"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "expo-contacts",
        {
          "contactsPermission": "Разрешите $(PRODUCT_NAME) доступ к контактам для быстрого добавления клиентов"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "843bd500-a571-43f1-9a69-b1bc61a63560"
      }
    }
  }
}
